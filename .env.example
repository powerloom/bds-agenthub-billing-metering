PORT=8787
BASE_URL=http://127.0.0.1:8787
DB_PATH=./data/signup.db
SESSION_TTL_SECONDS=600
FREE_TIER_CREDITS=10

# Cloudflare Turnstile — https://dash.cloudflare.com/turnstile
# Leave both empty for local dev: captcha is skipped automatically (unless NODE_ENV=production).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: force-skip Turnstile even when keys are set (emergency / local)
SKIP_TURNSTILE=0

# Shown in API/CLI when checkout is not wired (501 on POST /credits/topup)
BILLING_TOPUP_URL=https://powerloom.io

# Dev/staging only: if set, POST /credits/topup with header X-BDS-Dev-Topup-Secret can add credits
DEV_TOPUP_SECRET=

# BDS Core API (MPP middleware) calls POST /internal/billing/deduct with this header (required for signup_api billing)
INTERNAL_BILLING_SECRET=

# Credits per billed unit (defaults match 10 credits ≈ 7200 mainnet epochs for GET snapshot routes)
# CREDIT_PER_EPOCH=0.001388888888888889
# CREDIT_PER_STREAM_SESSION=0.01

# Tempo credit purchase (GET /credits/plans, POST /credits/topup with plan_id + tempo_tx_hash)
# Recipient wallet that receives TIP-20 pathUSD (or configured token) from agents.
MPP_TEMPO_RECIPIENT=
# Optional: override chain / RPC (defaults: 42431 + https://rpc.moderato.tempo.xyz)
# TEMPO_CHAIN_ID=42431
# TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
# Optional: full JSON fallback when credit_plans table is empty (or CREDIT_PLANS_SOURCE=env)
# CREDIT_PLANS_JSON=
# Plans source: `db` (default) = use SQLite `credit_plans` rows when present; `env` = always CREDIT_PLANS_JSON/defaults only
# CREDIT_PLANS_SOURCE=db
# Seed default rows: DB_PATH=./data/signup.db npm run seed:plans
# Max Tempo top-up POSTs per API key per minute (spam guard)
# CREDIT_TOPUP_RATE_PER_MINUTE=10
