{
  "name": "bds-agenthub-billing-metering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Device-authorization signup + API keys for BDS agents (RFC 8628 style)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:web": "cd web && npm install && npm run build",
    "build": "npm run build:web && tsc && cp src/db/schema.sql dist/db/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "seed:plans": "tsx src/scripts/seed-credit-plans.ts",
    "admin": "tsx src/scripts/billing-admin.ts",
    "rotate-api-key": "tsx src/scripts/rotate-api-key.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.18",
    "viem": "^2.51.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
