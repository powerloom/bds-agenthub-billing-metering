{
  "name": "bds-agenthub-billing-metering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Device-authorization signup + API keys for BDS agents (RFC 8628 style)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/db/schema.sql dist/db/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "@hono/node-server": "^1.13.1",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
